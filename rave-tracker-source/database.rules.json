{
  "rules": {
    "groups": {
      ".read": false,
      ".write": false,

      "$groupId": {
        ".read": true,
        ".write": true,

        "members": {
          "$memberId": {
            ".validate": "newData.hasChildren(['id', 'name', 'location'])",
            "id":       { ".validate": "newData.isString() && newData.val().length <= 64" },
            "name":     { ".validate": "newData.isString() && newData.val().length <= 40" },
            "emoji":    { ".validate": "newData.isString() && newData.val().length <= 16" },
            "color":    { ".validate": "newData.isString() && newData.val().length <= 16" },
            "lastSeen": { ".validate": "newData.isNumber()" },
            "location": {
              ".validate": "newData.hasChildren(['lat', 'lng'])",
              "lat": { ".validate": "newData.isNumber() && newData.val() >= -90  && newData.val() <= 90" },
              "lng": { ".validate": "newData.isNumber() && newData.val() >= -180 && newData.val() <= 180" },
              "$locOther": { ".validate": false }
            },
            "$memberOther": { ".validate": false }
          }
        },

        "messages": {
          "$messageId": {
            ".validate": "newData.hasChildren(['name', 'text', 'ts'])",
            "id":    { ".validate": "newData.isString() && newData.val().length <= 64" },
            "name":  { ".validate": "newData.isString() && newData.val().length <= 40" },
            "emoji": { ".validate": "newData.isString() && newData.val().length <= 16" },
            "color": { ".validate": "newData.isString() && newData.val().length <= 16" },
            "text":  { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 500" },
            "ts":    { ".validate": "newData.isNumber()" },
            "$msgOther": { ".validate": false }
          }
        },

        "$groupOther": { ".validate": false }
      }
    }
  }
}
